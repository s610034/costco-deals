# 好市多折扣週報 - 環境變數
# 複製此檔為 .env 並填入實際值
# 用法：cp .env.example .env

# ── Telegram：好市多專用 Bot ───────────────────────────────
# 1. 打開 Telegram，搜尋 @BotFather
# 2. 發送 /newbot，照指示建立新 Bot
# 3. 取得 Token 填入下方
COSTCO_TG_TOKEN=

# 你的 Telegram Chat ID（跟台股共用同一個，或另開群組）
COSTCO_TG_CHAT_ID=843096573

# ── Line Messaging API ────────────────────────────────────
# 1. https://developers.line.biz/console/ 建立 Messaging API Channel
# 2. 取得長期 Channel Access Token
LINE_CHANNEL_ACCESS_TOKEN=

# 3. 你的 LINE User ID
LINE_USER_ID=
